{
  "scripts": {
    "dev": "node node_modules/tailwindcss/lib/cli.js -i styles.css -o output.css --watch",
    "build:css:tw": "node node_modules/tailwindcss/lib/cli.js -i styles.css -o output.min.css --minify",
    "build:css:custom": "node node_modules/esbuild/bin/esbuild custom.css --minify --outfile=custom.min.css",
    "build:js": "node node_modules/esbuild/bin/esbuild app.js --minify --outfile=app.min.js",
    "build": "npm run build:css:tw && npm run build:css:custom && npm run build:js",
    "test": "node tests/routines-unit.test.js"
  },
  "name": "dailiesapp",
  "version": "1.0.0",
  "main": "app.js",
  "dependencies": {
    "browserslist": "^4.24.4",
    "caniuse-lite": "^1.0.30001695",
    "dotenv": "^17.2.3",
    "electron-to-chromium": "^1.5.88",
    "escalade": "^3.2.0",
    "fraction.js": "^4.3.7",
    "nanoid": "^3.3.8",
    "node-releases": "^2.0.19",
    "normalize-range": "^0.1.2",
    "picocolors": "^1.1.1",
    "postcss-value-parser": "^4.2.0",
    "source-map-js": "^1.2.1",
    "update-browserslist-db": "^1.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pdacorte/dailiesapp.git"
